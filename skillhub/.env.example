# Vercel Environment Variables
# 请在 Vercel Dashboard (Production) 中填入真实值

GITHUB_CLIENT_ID=你的GitHub_OAuth_App的Client_ID
GITHUB_CLIENT_SECRET=你的GitHub_OAuth_App的Client_Secret
GITHUB_REDIRECT_URI=https://skillhub-eight.vercel.app/api/auth/callback
GITHUB_TOKEN=你的GitHub_Personal_Access_Token
CLAWHUB_TOKEN=你的ClawHub_API_Token