# Vercel Environment Variables
# 请在 Vercel Dashboard 中填入真实值

# GitHub OAuth App 配置
GITHUB_CLIENT_ID=PLACEHOLDER_fill_me
GITHUB_CLIENT_SECRET=PLACEHOLDER_fill_me
GITHUB_REDIRECT_URI=https://skillhub-eight.vercel.app/api/auth/callback

# GitHub API Token (用于增加 rate limit)
GITHUB_TOKEN=PLACEHOLDER_fill_me

# ClawHub API Token (用于技能发现)
CLAWHUB_TOKEN=PLACEHOLDER_fill_me